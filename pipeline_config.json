{
  "_comment": "Agentic Data Discovery Pipeline — configuration file.",

  "volume_paths": [
    "/Volumes/workspace/raw/ungm"
  ],
  "volume_file_extensions": [".parquet", ".csv", ".json"],

  "jdbc_sources": [],

  "output_catalog": "workspace",
